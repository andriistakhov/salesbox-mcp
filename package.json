{
  "name": "salesbox-mcp",
  "version": "1.0.0",
  "description": "MCP server wrapping the SalesBox public OpenAPI (https://prod.salesbox.me)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "salesbox-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node dist/index.js",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
