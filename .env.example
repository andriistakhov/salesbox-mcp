# --- SalesBox API ---
# Your OpenAPI token (get it from the SalesBox support bot: https://t.me/salesboxsupport_bot)
# In HTTP mode this is the default token; clients may override per-request via the
# X-Salesbox-Token header. Leave empty to require per-request tokens.
SALESBOX_API_TOKEN=

# API base URL (default: production)
SALESBOX_BASE_URL=https://prod.salesbox.me

# --- Transport ---
# "http" (Streamable HTTP, for the VPS) or "stdio" (local clients)
MCP_TRANSPORT=http

# HTTP listen address/port
HOST=0.0.0.0
PORT=3000

# Optional shared secret guarding the /mcp endpoint. When set, clients must send
# Authorization: Bearer <token>  OR  X-MCP-Auth: <token>. Strongly recommended
# if the port is exposed to the internet.
MCP_AUTH_TOKEN=

# --- Tuning (optional) ---
SALESBOX_TIMEOUT_MS=30000
SALESBOX_MAX_RETRIES=2
SALESBOX_MAX_RETRY_WAIT=65
